# Poner en true para usar datos mock (sin backend en localhost:8080)
VITE_USE_MOCK=true

# Cloudinary — rellena con tus datos
# Cloud name: en cloudinary.com → Dashboard, arriba izquierda
# Upload preset: Settings → Upload → Upload presets → crear uno Unsigned
VITE_CLOUDINARY_CLOUD_NAME=dkdwgdm3h
VITE_CLOUDINARY_UPLOAD_PRESET=lumen_unsigned
